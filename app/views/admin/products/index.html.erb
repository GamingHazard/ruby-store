<% content_for :title, "Products" %>

<div class="w-full h-screen px-4 overflow-y-auto ">
  <% if notice.present? %>
    <p class="inline-block w-full px-3 py-2 mb-5 font-medium text-green-500 rounded-md bg-green-50" id="notice"><%= notice %></p>
  <% end %>

<div class = "flex flex-row flex-1 w-full min-h-screen gap-4 px-4 py-4 bg-gray-100">

<div class="flex-wrap flex-1 max-w-full max-h-screen bg-white goverflow-x-auto ">
 

    <%# category row %>
<div class="flex flex-row items-center w-full p-6 bg-purple-100 justify-evenly ">

  <%= link_to "All", products_path, data: { turbo_frame: "items" }, class: "text-purple-800 items-center  p-2 text-lg  border border-purple-500 rounded-lg cursor-pointer hover:bg-purple-200 " %>
  <%= link_to "Shirts", products_path(category: "shirts"), data: { turbo_frame: "items" }, class: "flex items-center text-purple-800 gap-2 p-2 text-lg font-semibold border border-purple-500 rounded-lg cursor-pointer hover:bg-purple-200 felx-row justify-evenly" %>
  <%= link_to "Pants", products_path(category: "pants"), data: { turbo_frame: "items" }, class: "flex items-center text-purple-800 gap-2 p-2 text-lg font-semibold border border-purple-500 rounded-lg cursor-pointer hover:bg-purple-200 felx-row justify-evenly" %>
  <%= link_to "Sneakers", products_path(category: "sneakers"), data: { turbo_frame: "items" }, class: "flex items-center text-purple-800 gap-2 p-2 text-lg font-semibold border border-purple-500 rounded-lg cursor-pointer hover:bg-purple-200 felx-row justify-evenly" %>
  <%= link_to "Men shoes", products_path(category: "men shoes"), data: { turbo_frame: "items" }, class: "flex items-center text-purple-800 gap-2 p-2 text-lg font-semibold border border-purple-500 rounded-lg cursor-pointer hover:bg-purple-200 felx-row justify-evenly" %>
  <%= link_to "Women Shoes", products_path(category: "lady shoes"), data: { turbo_frame: "items" }, class: "flex items-center text-purple-800 gap-2 p-2 text-lg font-semibold border border-purple-500 rounded-lg cursor-pointer hover:bg-purple-200 felx-row justify-evenly" %>

    
</div>

<%= turbo_frame_tag "items" do %>
  <%= render partial: "products/list", locals: { products: @products } %>
<% end %>
</div>

   <%# dETAILS SECTION   %>
   <!-- app/views/products/index.html.erb (snippet) -->
<div class="max-w-2xl max-h-screen p-6 overflow-y-auto bg-white rounded-lg shadow-md w-120">
  <div class="flex flex-col w-full h-screen">
   <%if @product.present?%>
    <h1 class="text-4xl font-bold text-center">Showing product</h1>
    <%else%>
   <%end%>

    <turbo-frame id="product_details">
      <% if @product.present? %>
        <%= render @product %>
      <% else %>
      <span class="grid items-center justify-center flex-1 h-screen mb-4 ">
        <p class="flex-1 text-center text-gray-300 justify-self-center">Select a product to view details</p>
      </span>
      <% end %>
    </turbo-frame>

  </div>
</div>

</div>
  
</div>
