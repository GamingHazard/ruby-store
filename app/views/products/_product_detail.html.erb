<turbo-frame id="product_details">
  <div class="p-4">
    <div class="flex flex-row gap-6 ">
      <div class="flex flex-col items-center md:w-1/2">
        <% if product.images.attached? %>
          <%= image_tag product.images.first, class: "w-full h-100 rounded-lg shadow" %>
        <% else %>
          <%= image_tag "placeholder.png", class: "w-full h-auto rounded-lg shadow", alt: "no image" %>
        <% end %>
      </div>
      

      <div class="md:w-1/2">
        <h2 class="text-2xl font-bold">
          <%= product.name %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="inline-block ml-2 text-gray-400 cursor-pointer size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
         </svg>

        </h2>

        <p class="mt-4 text-2xl font-bold text-gray-400">Description</p>
        <p class="mt-4 text-gray-700"><%= product.description %></p>

        
      </div>


      
    </div>
    <div class="flex flex-row flex-wrap gap-5 mt-5 mb-10">
      <%# tabs %>
      <span class="flex flex-col w-1/4 p-4 bg-white rounded-lg shadow-md">
       <p class = "flex flex-row items-center justify-center text-lg text-3xl font-bold text-gray-400 ">
        Price
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="flex-1 size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
</svg>

        </p>
      <p class = "text-sm text-gray-400">
        <ul class="flex flex-row flex-wrap justify-between gap-3">
          <li class="text-sm text-red-900 line-through">$ 900.00</li>
          
        <p class="mt-2 text-xl text-green-600"><%= number_to_currency(product.price) %></p>

           
           
        </ul>
        
        </p>
      </span>
      <span class="flex flex-col w-1/4 p-4 bg-white rounded-lg shadow-md">
       <p class = "flex flex-row items-center justify-center text-lg text-3xl font-bold text-gray-400 ">
        Colors
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="flex-1 size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" />
</svg>

        </p>
      <p class="text-sm text-gray-400">
  <ul class="flex flex-row flex-wrap justify-between gap-3 list-disc">
     

    <% new_colors = product.color.split(",").map(&:strip) %>
    <% new_colors.take(3).each do |color| %>
       
   
    <span class="grid items-center justify-between grid-cols-2 gap-2 p-2">
       <li class="flex-1 text-sm text-gray-400"><%= color %> </li>
          <span style="background-color: <%= color %>;" class="w-6 h-6 rounded-full shadow-lg cursor-pointer"></span>

    </span>

    <% end %>
  </ul>
</p>

      </span>


      <span class="flex flex-col w-1/4 p-4 bg-white rounded-lg shadow-md">
       <p class = "flex flex-row items-center justify-center text-lg text-3xl font-bold text-gray-400 ">
        Size
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="flex-1 size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
</svg>

        </p>
      <p class = "text-sm text-gray-400">
        <ul class="grid flex-wrap justify-between grid-cols-3 gap-3 ">
           <% new_size = product.size.split(",").map(&:strip)%>
           <% new_size.each do |size|%>
              <li class="text-sm text-gray-400 "><%= size %></li>
           <%end%>
           
        </ul>
      </p>
      </span>


       <span class="flex flex-col w-1/4 p-4 bg-blue-100 rounded-lg shadow-md">
       <p class = "text-lg text-3xl font-bold text-blue-400 ">Material</p>
      <p class = "flex flex-row items-center justify-center mt-3 text-sm text-blue-400">
        <%=product.material%>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="flex-1 text-blue-400 size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
</svg>

        </p>
      </span>
       <span class="flex flex-col w-1/4 p-4 bg-red-100 rounded-lg shadow-md">
       <p class = "flex flex-row text-lg text-3xl font-bold text-red-600">
        Stock
        <br>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="flex-1 text-sm size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
</svg>

        </p>
      <p class = "text-sm text-red-600">23</p>
      </span>
       <span class="flex flex-col w-1/4 p-4 bg-green-100 rounded-lg shadow-md">
       <p class = "text-sm text-2xl font-bold text-green-600 ">
        Free Shipping
        </p>
        <span class = "flex flex-row items-center gap-2 text-sm text-green-600">
        .......................  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
</svg>
          </span>

       
      </span>
      
    </div>
     <button class="w-full px-4 py-2 mt-10 text-lg font-semibold text-white bg-purple-600 rounded-lg hover:bg-purple-700">
      Add to Cart
    </button>
    <h2 class="mt-5 text-2xl font-semibold text-center text-gray-400">What Other people say about the product</h2>
    <p class="mt-2 text-sm text-center text-gray-400">No reviews at the moment</p>
     <button class="w-full px-4 py-2 mt-5 text-lg font-semibold text-purple-600 bg-purple-200 rounded-lg cursor-pointer hover:bg-purple-300">
      Add Review
    </button>
  </div>
</turbo-frame>
