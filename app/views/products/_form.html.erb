<div class="flex flex-col items-center justify-center w-full px-4 bg-white rounded-md shadow-md">
  <%= form_with(model: product, class: "contents") do |form| %>
  <% if product.errors.any? %>
    <div id="error_explanation" class="px-3 py-2 mt-3 font-medium text-red-500 rounded-md bg-red-50">
      <h2><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h2>

      <ul class="ml-6 list-disc">
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="w-full my-2">
    <%= form.text_field :name,required:true,placeholder:"Product name",class: ["block shadow-sm rounded-md border px-3 py-2  w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:name].none?, "border-red-400 focus:outline-red-600": product.errors[:name].any?}] %>
  </div>

  <div class="w-full my-2">
    <%= form.rich_textarea :description,required:true,placeholder:"Description (max 395 characters)",class: ["block shadow-sm rounded-md border overflow-y-auto px-3 py-2 h-70 w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:description].none?, "border-red-400 focus:outline-red-600": product.errors[:description].any?}] %>
  </div>

  <div class="w-full my-2">
    <%= form.label :images %>
    <%= form.file_field :images, multiple: true,required:true,placeholder:"email",class: ["block shadow-sm rounded-md border px-3 py-2  w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:images].none?, "border-red-400 focus:outline-red-600": product.errors[:images].any?}] %>
  </div>

  <div class="w-full my-2">
    <%= form.text_field :price,required:true,placeholder:"price",class: ["block shadow-sm rounded-md border px-3 py-2  w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:price].none?, "border-red-400 focus:outline-red-600": product.errors[:price].any?}] %>
  </div>

  <div class="w-full my-2">
    <%= form.text_field :color,required:true,placeholder:"color (serperate with a commer ie green,blue,red)",class: ["block shadow-sm rounded-md border px-3 py-2  w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:color].none?, "border-red-400 focus:outline-red-600": product.errors[:color].any?}] %>
  </div>

  <div class="w-full my-2">
    <%= form.text_field :size,required:true,placeholder:"size (serperate with a commer ie sm,md,lg)",class: ["block shadow-sm rounded-md border px-3 py-2  w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:size].none?, "border-red-400 focus:outline-red-600": product.errors[:size].any?}] %>
  </div>

  <div class="w-full my-2">
  <%= form.text_field :category,required:true,placeholder:"category",
    class: ["block shadow-sm rounded-md border px-3 py-2 w-full",
      { "border-gray-400 focus:outline-blue-600": product.errors[:category].none?,
        "border-red-400 focus:outline-red-600": product.errors[:category].any? }] %>
</div>


  <div class="w-full my-2">
    <%= form.text_field :material,required:true,placeholder:"item material",class: ["block shadow-sm rounded-md border px-3 py-2  w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:material].none?, "border-red-400 focus:outline-red-600": product.errors[:material].any?}] %>
  </div>

  <div class="inline mt-5 ">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  <%= link_to "Back to products", products_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    
  </div>
<% end %>

</div>